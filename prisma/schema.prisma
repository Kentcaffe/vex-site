generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  TESTER
  MODERATOR
  ADMIN
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum SupportTicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum SupportMessageSenderRole {
  USER
  ADMIN
  SYSTEM
}

/** Nivel program testare (chat); separat de `UserRole`. */
enum TesterProgramLevel {
  trial
  tester
  advanced
  lead
}

model User {
  id            String         @id @default(cuid())
  supabaseAuthId String?
  email         String         @unique
  name          String?
  avatarUrl     String?
  accountType   String         @default("user") @map("account_type")
  businessStatus String        @default("none") @map("business_status")
  companyName   String?        @map("company_name")
  companyType   String?        @map("company_type")
  idno          String?
  vatNumber     String?        @map("vat_number")
  administratorName String?    @map("administrator_name")
  companyAddress String?       @map("company_address")
  companyCity   String?        @map("company_city")
  phone         String?
  companyEmail  String?        @map("company_email")
  isVerified    Boolean        @default(false) @map("is_verified")
  companyLogo   String?        @map("company_logo")
  companyDocument String?      @map("company_document")
  registrationNumber String?   @map("registration_number")
  registrationDate DateTime?   @db.Date @map("registration_date")
  city          String?
  bio           String?
  passwordHash  String?
  role          UserRole       @default(USER)
  /** Nivel în programul de testare (chat tester) — tip enum în Postgres = dropdown în Supabase. */
  testerLevel   TesterProgramLevel @default(trial) @map("tester_level")
  listings      Listing[]
  buyerChatRooms ChatRoom[]    @relation("BuyerRooms")
  chatMessages  ChatMessage[]
  chatReadStates ChatReadState[]
  listingReports ListingReport[] @relation("ReportAuthor")
  otherContentReports OtherContentReport[] @relation("OtherReportAuthor")
  favorites     ListingFavorite[]
  passwordResetTokens PasswordResetToken[]
  notifications UserNotification[]
  sentMessages  Message[]      @relation("MessageSender")
  receivedMessages Message[]   @relation("MessageReceiver")
  supportTickets SupportTicket[]
  supportMessagesSent SupportMessage[] @relation("SupportMessages")
  businessApplications BusinessApplication[]
  feedbacks     Feedback[]
  feedbackRepliesAsAdmin FeedbackReply[] @relation("FeedbackReplyAdmin")
  adminLogs     AdminLog[]
  /** JSON: theme, notifications, privacy toggles, activity log snippets, etc. */
  preferences   Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt

  @@map("users")
}

model Message {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String   @map("receiver_id")
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  roomId     String?  @map("room_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([roomId, createdAt])
  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CatTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CatTree")
  sortOrder Int        @default(0)
  labels    String
  listings  Listing[]
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  /** Moneda în care este exprimat prețul (afișare și filtre). */
  priceCurrency String @default("MDL")
  negotiable  Boolean  @default(false)
  city        String
  district    String?
  phone       String?
  condition   String   @default("not_applicable")

  brand     String?
  modelName String?
  year      Int?
  mileageKm Int?
  rooms     String?
  areaSqm   Int?

  detailsJson String?
  images      String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatRooms ChatRoom[]
  reports   ListingReport[]
  favoritedBy ListingFavorite[]

  @@index([isDeleted])
  @@map("listings")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  targetId  String   @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetId])
  @@index([createdAt])
  @@map("admin_logs")
}

model ListingReport {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User         @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  details    String?
  status     ReportStatus @default(PENDING)
  /** Mesaj pentru raportor: ce s-a decis / acțiune (opțional). */
  resolutionNote String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  @@unique([listingId, reporterId])
  @@index([status])
  @@index([createdAt])
}

/** Raport pentru conținut care nu e anunț (pagină, text, link extern etc.). */
model OtherContentReport {
  id             String       @id @default(cuid())
  reporterId     String
  reporter       User         @relation("OtherReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)
  /** "listing" = problemă legată de un anunț (URL anunț); "site" = problemă tehnică / pagină. */
  kind           String       @default("site")
  subject        String
  contextUrl     String?
  reason         String
  details        String?
  status         ReportStatus @default(PENDING)
  resolutionNote String?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?

  @@index([status])
  @@index([createdAt])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  refId     String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

/** Sugestii de pe pagina Contact (separat de suport live). */
model Feedback {
  id        String          @id @default(cuid())
  userId    String?         @map("user_id")
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  message   String
  createdAt DateTime        @default(now()) @map("created_at")
  replies   FeedbackReply[]

  @@index([userId])
  @@index([createdAt])
  @@map("feedback")
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String   @map("feedback_id")
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  adminId    String   @map("admin_id")
  admin      User     @relation("FeedbackReplyAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  reply      String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([feedbackId])
  @@map("feedback_replies")
}

model ListingFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model ChatRoom {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("BuyerRooms", fields: [buyerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   String[]  @default([])
  sellerId  String?
  messages  ChatMessage[]
  readStates ChatReadState[]

  @@unique([listingId, buyerId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model ChatReadState {
  id         String   @id @default(cuid())
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([roomId, userId])
}

/** Live support (separat de ChatRoom marketplace). */
model SupportTicket {
  id              String               @id @default(cuid())
  userId          String               @map("user_id")
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          SupportTicketStatus  @default(OPEN)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  lastMessageAt   DateTime?            @map("last_message_at")
  feedbackRating  Int?                 @map("feedback_rating")
  feedbackSatisfied Boolean?           @map("feedback_satisfied")
  feedbackMessage String?              @map("feedback_message")
  feedbackAt      DateTime?            @map("feedback_at")
  closedAt        DateTime?            @map("closed_at")
  messages        SupportMessage[]

  @@index([userId, status])
  @@index([lastMessageAt])
  @@index([status, lastMessageAt])
  @@map("support_tickets")
}

model SupportMessage {
  id          String                   @id @default(cuid())
  ticketId    String                   @map("ticket_id")
  ticket      SupportTicket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String                   @map("sender_id")
  sender      User                     @relation("SupportMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderRole  SupportMessageSenderRole @map("sender_role")
  body        String
  createdAt   DateTime                 @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

model BusinessApplication {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              String   @default("pending")
  companyName         String   @map("company_name")
  companyType         String   @map("company_type")
  idno                String
  vatNumber           String?  @map("vat_number")
  administratorName   String   @map("administrator_name")
  companyAddress      String   @map("company_address")
  companyCity         String   @map("company_city")
  phone               String
  companyEmail        String   @map("company_email")
  companyLogo         String?  @map("company_logo")
  companyDocument     String   @map("company_document")
  registrationNumber  String   @map("registration_number")
  registrationDate    DateTime @db.Date @map("registration_date")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  reviewedAt          DateTime? @map("reviewed_at")
  reviewedBy          String?  @map("reviewed_by")

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("business_applications")
}
