generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  avatarUrl     String?
  phone         String?
  city          String?
  bio           String?
  passwordHash  String?
  role          UserRole       @default(USER)
  listings      Listing[]
  buyerChatRooms ChatRoom[]    @relation("BuyerRooms")
  chatMessages  ChatMessage[]
  chatReadStates ChatReadState[]
  listingReports ListingReport[] @relation("ReportAuthor")
  otherContentReports OtherContentReport[] @relation("OtherReportAuthor")
  favorites     ListingFavorite[]
  passwordResetTokens PasswordResetToken[]
  notifications UserNotification[]
  /** JSON: theme, notifications, privacy toggles, activity log snippets, etc. */
  preferences   Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CatTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CatTree")
  sortOrder Int        @default(0)
  labels    String
  listings  Listing[]
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  negotiable  Boolean  @default(false)
  city        String
  district    String?
  phone       String?
  condition   String   @default("not_applicable")

  brand     String?
  modelName String?
  year      Int?
  mileageKm Int?
  rooms     String?
  areaSqm   Int?

  detailsJson String?
  images      String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatRooms ChatRoom[]
  reports   ListingReport[]
  favoritedBy ListingFavorite[]
}

model ListingReport {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User         @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  details    String?
  status     ReportStatus @default(PENDING)
  /** Mesaj pentru raportor: ce s-a decis / acțiune (opțional). */
  resolutionNote String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  @@unique([listingId, reporterId])
  @@index([status])
  @@index([createdAt])
}

/** Raport pentru conținut care nu e anunț (pagină, text, link extern etc.). */
model OtherContentReport {
  id             String       @id @default(cuid())
  reporterId     String
  reporter       User         @relation("OtherReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)
  /** "listing" = problemă legată de un anunț (URL anunț); "site" = problemă tehnică / pagină. */
  kind           String       @default("site")
  subject        String
  contextUrl     String?
  reason         String
  details        String?
  status         ReportStatus @default(PENDING)
  resolutionNote String?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?

  @@index([status])
  @@index([createdAt])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  refId     String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model ListingFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model ChatRoom {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("BuyerRooms", fields: [buyerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]
  readStates ChatReadState[]

  @@unique([listingId, buyerId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model ChatReadState {
  id         String   @id @default(cuid())
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([roomId, userId])
}
