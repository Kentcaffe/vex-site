{
  "name": "anunturi-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "prisma generate && next dev --webpack",
    "dev:api": "node backend/server.js",
    "dev:next": "next dev --webpack",
    "prebuild": "prisma generate",
    "build": "next build",
    "build:with-db": "prisma generate && prisma migrate deploy && next build",
    "build:render": "prisma generate && npm run migrate:deploy && npm run build",
    "start": "next start -H 0.0.0.0 -p $PORT",
    "start:api": "node backend/server.js",
    "migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "start:render": "next start -H 0.0.0.0 -p $PORT",
    "start:render:fallback": "next start -H 0.0.0.0 -p $PORT",
    "start:render:only": "next start -H 0.0.0.0 -p $PORT",
    "db:setup": "prisma db push",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:render": "npm run migrate:deploy",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:seed": "npx tsx prisma/seed.ts",
    "seed:marketplace": "node seed.js",
    "listings:clear": "node scripts/clear-all-listings.js",
    "env:check": "node scripts/check-env.mjs",
    "test:smtp": "node scripts/test-smtp.mjs",
    "debug:smtp-env": "node scripts/debug-smtp-env.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.14.1",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
