# =============================================================================
# Copiază acest fișier:  cp .env.example .env   (Windows: copy .env.example .env)
# Completează valorile în .env — NICIODATĂ nu comita .env (e în .gitignore).
# =============================================================================

# --- Bază de date (Prisma → PostgreSQL, ex. Supabase) ---
# Supabase recomandat:
# - DATABASE_URL = Connection Pooling URI (host *.pooler.supabase.com:6543)
# - DIRECT_URL   = Direct connection URI (host db.<ref>.supabase.co:5432) pentru migrate
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
# Prisma NU rulează automat la startup pe Render.
# Rulează manual când ai nevoie: `npm run db:setup` (sau `npm run db:migrate`).
# DB_SSL=true    # activează SSL explicit (recomandat pentru managed DB)
# DB_SSL_REJECT_UNAUTHORIZED=false  # util dacă providerul prezintă cert chain self-signed

# --- UI: monedă implicită afișată (MDL sau EUR) ---
NEXT_PUBLIC_PRICE_CURRENCY=MDL

# --- Supabase Auth (obligatoriu pentru autentificare) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Bucket public pentru poze anunțuri (path în URL: /storage/v1/object/public/BUCKET/listings/...)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=listings
# Secret server-only (NU îl expune în client). Folosit la upload poze anunțuri în Storage (producție/serverless).
SUPABASE_SERVICE_ROLE_KEY=

# URL public folosit pentru OAuth callback + redirect
AUTH_URL=https://vex.md

# --- Program Live Support ---
# Orar în timezone-ul setat (default: Europe/Chisinau).
# Exemplu: 10 -> 18 înseamnă 10:00–18:00.
SUPPORT_TIMEZONE=Europe/Chisinau
SUPPORT_OPEN_HOUR=10
SUPPORT_CLOSE_HOUR=18
# Zile active pentru live chat (JS weekday): 0=Sun, 1=Mon, ... 6=Sat
# Implicit (dacă lipsește): 1,2,3,4,5 => luni-vineri
SUPPORT_OPEN_DAYS=1,2,3,4,5
SUPPORT_EMAIL=asistenta@vex.md

# --- API backend Express ---
API_PORT=4000

# URL public al site-ului (fără slash final)
NEXT_PUBLIC_APP_URL=https://vex.md

# --- OAuth (opțional — lasă gol dacă nu folosești) ---
# Configurezi provider-ele direct în Supabase Dashboard (Auth -> Providers):
#   https://vex.md/api/auth/callback
# Toggle UI local (opțional):
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
# NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=true

# --- Chat real-time (Socket.io) ---
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=https://vex.md

# =============================================================================
# Email: resetare parolă — TREBUIE unul din două: (A) SMTP Zoho  SAU  (B) Resend
# =============================================================================

# Expeditor (obligatoriu pentru ambele). Ex: "VEX <noreply@domeniul-tău.md>"
EMAIL_FROM=

# --- (A) SMTP Zoho (recomandat) ---
# Host: din Zoho Mail → SMTP (smtp.zoho.eu sau smtppro.zoho.eu, după regiune).
# Port 465 = SSL | Port 587 = STARTTLS (pune SMTP_SECURE=false pentru 587).
SMTP_HOST=
SMTP_PORT=465
# SMTP_SECURE=false
SMTP_USER=
# Dacă parola conține # sau alte caractere speciale, pune-o între ghilimele duble:
# SMTP_PASS="parola-ta-completă"
SMTP_PASS=
# SMTP_AUTH_METHOD=PLAIN   # implicit e LOGIN (recomandat Zoho); folosește PLAIN doar dacă serverul cere explicit
# SMTP_DEBUG=1             # log detaliat SMTP în consolă (doar debug)

# --- (B) Resend (dacă NU folosești SMTP) ---
# RESEND_API_KEY=

# --- Mentenanță (Render: set Environment → deploy) ---
# MAINTENANCE_MODE=true → toate rutele (except /api/health + asset-uri) merg la /maintenance
# MAINTENANCE_MODE=false sau lipsă → site normal. Health check: GET /api/health (200 JSON)
#
# Cloudflare (recomandat lângă Render):
# - Always Online™ + Custom Error Pages (502/523) către domeniu static sau pagină „VEX”
# - Health monitor pe https://vex.md/api/health (interval 60s)
# - Page Rules: „Maintenance” poate servi un HTML static dacă originul e complet down
#
# MAINTENANCE_MODE=false
# EXIT_ON_UNCAUGHT=true   # opțional: oprește procesul la uncaughtException (restart Render)

# =============================================================================
# Producție — Render.com + PostgreSQL (Supabase sau alt host)
# =============================================================================
# 1. DATABASE_URL = pooler URI (runtime)
# 2. DIRECT_URL   = direct URI (migrate)
# 3. Build Command:  npm ci && npm run build:render
# 4. Start Command:  npm run start:render  (pornește direct Next.js)
# 5. DB setup/migrări: manual (NU la startup): `npm run db:setup` sau `npm run db:migrate`
#
# Migrare date din vechiul SQLite (dev.db): după ce Postgres are schema (npm run db:migrate),
# exportă din SQLite (ex. DB Browser, sau pgloader) și importă în Supabase — nu comităm parole în repo.
# NEXT_PUBLIC_APP_URL=https://vex.md
# NEXT_PUBLIC_SOCKET_URL=wss://...
