# =============================================================================
# Copiază acest fișier:  cp .env.example .env   (Windows: copy .env.example .env)
# Completează valorile în .env — NICIODATĂ nu comita .env (e în .gitignore).
# =============================================================================

# --- Bază de date (Prisma → PostgreSQL, ex. Supabase) ---
# Supabase: Project Settings → Database → Connection string → URI (Direct connection).
# Exemplu (înlocuiește parola): postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Pentru migrații la deploy: același DATABASE_URL în Render (Environment) ca la build dacă rulezi migrate la start.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- UI: monedă implicită afișată (MDL sau EUR) ---
NEXT_PUBLIC_PRICE_CURRENCY=MDL

# --- Auth.js / sesiuni (obligatoriu) ---
# Generează:  openssl rand -base64 32
AUTH_SECRET=

# Opțional: același secret (legacy)
# NEXTAUTH_SECRET=

# URL public al site-ului (fără slash final). Dev: http://localhost:3000 | Prod: https://vex.md
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js folosește AUTH_URL; dacă folosești doar NEXTAUTH_URL, poți seta:
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# --- OAuth (opțional — lasă gol dacă nu folosești) ---
# Redirect în Google Cloud / Meta:
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/facebook
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=

# --- Chat real-time (Socket.io) ---
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# =============================================================================
# Email: resetare parolă — TREBUIE unul din două: (A) SMTP Zoho  SAU  (B) Resend
# =============================================================================

# Expeditor (obligatoriu pentru ambele). Ex: "VEX <noreply@domeniul-tău.md>"
EMAIL_FROM=

# --- (A) SMTP Zoho (recomandat) ---
# Host: din Zoho Mail → SMTP (smtp.zoho.eu sau smtppro.zoho.eu, după regiune).
# Port 465 = SSL | Port 587 = STARTTLS (pune SMTP_SECURE=false pentru 587).
SMTP_HOST=
SMTP_PORT=465
# SMTP_SECURE=false
SMTP_USER=
# Dacă parola conține # sau alte caractere speciale, pune-o între ghilimele duble:
# SMTP_PASS="parola-ta-completă"
SMTP_PASS=
# SMTP_AUTH_METHOD=PLAIN   # implicit e LOGIN (recomandat Zoho); folosește PLAIN doar dacă serverul cere explicit
# SMTP_DEBUG=1             # log detaliat SMTP în consolă (doar debug)

# --- (B) Resend (dacă NU folosești SMTP) ---
# RESEND_API_KEY=

# =============================================================================
# Producție — Render.com + PostgreSQL (Supabase sau alt host)
# =============================================================================
# 1. DATABASE_URL = URI-ul PostgreSQL (același în Render Environment pentru runtime).
# 2. Build Command:  npm ci && npm run build
#    (fără migrate la build — nu e nevoie de DB la build dacă nu rulezi scripturi care cer DB)
# 3. Start Command:  npm run start:render
#    (rulează prisma migrate deploy — aplică migrările din prisma/migrations pe Postgres)
#
# Migrare date din vechiul SQLite (dev.db): după ce Postgres are schema (npm run db:migrate),
# exportă din SQLite (ex. DB Browser, sau pgloader) și importă în Supabase — nu comităm parole în repo.
# NEXT_PUBLIC_APP_URL=https://vex.md
# NEXT_PUBLIC_SOCKET_URL=wss://...
