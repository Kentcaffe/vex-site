DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_PRICE_CURRENCY=MDL
# Secret semnare sesiune (Auth.js / NextAuth). Poți folosi și NEXTAUTH_SECRET.
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# NEXTAUTH_SECRET="same-as-auth-secret"

# URL public al aplicației (OAuth redirect). Auth.js folosește AUTH_URL; NEXTAUTH_URL e recunoscut în cod.
# NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000

# OAuth — Google Cloud Console / Meta for Developers: redirect URI
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/facebook
#   https://DOMENIUL-TAU/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=

# Real-time chat (Socket.io). In development run both via `npm run dev`
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resetare parolă — alege SMTP (Zoho) SAU Resend.
# EMAIL_FROM este obligatoriu pentru ambele (expeditor verificat).

# --- SMTP Zoho (recomandat producție vex.md) ---
# SMTP_HOST=smtppro.zoho.eu
# SMTP_PORT=465
# SMTP_USER=noreply@vex.md
# SMTP_PASS=***
# (465 + TLS implicit — secure: true în cod)

# --- Resend (alternativă) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM="Nume <noreply@domeniu-verificat.resend.dev>"

# --- Render / producție ---
# Build Command: npm ci && npm run build:render   (prisma db push + next build)
# Start Command: npm run start:render            (prisma db push + next start — evită SQLite gol la runtime)
# DATABASE_URL: același în Environment la build și runtime. Ex. file:./data/prod.db pe Persistent Disk.
# AUTH_SECRET: obligatoriu (openssl rand -base64 32)
# NEXT_PUBLIC_APP_URL: https://vex.md (URL public al site-ului)
# NEXT_PUBLIC_SOCKET_URL: URL-ul serviciului Socket.io dacă îl rulezi separat (sau lasă gol dacă nu folosești chat în prod)
