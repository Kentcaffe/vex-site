# =============================================================================
# Copiază acest fișier:  cp .env.example .env   (Windows: copy .env.example .env)
# Completează valorile în .env — NICIODATĂ nu comita .env (e în .gitignore).
# =============================================================================

# --- Bază de date (Prisma / SQLite local) ---
DATABASE_URL="file:./dev.db"

# --- UI: monedă implicită afișată (MDL sau EUR) ---
NEXT_PUBLIC_PRICE_CURRENCY=MDL

# --- Auth.js / sesiuni (obligatoriu) ---
# Generează:  openssl rand -base64 32
AUTH_SECRET=

# Opțional: același secret (legacy)
# NEXTAUTH_SECRET=

# URL public al site-ului (fără slash final). Dev: http://localhost:3000 | Prod: https://vex.md
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js folosește AUTH_URL; dacă folosești doar NEXTAUTH_URL, poți seta:
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# --- OAuth (opțional — lasă gol dacă nu folosești) ---
# Redirect în Google Cloud / Meta:
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/facebook
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=

# --- Chat real-time (Socket.io) ---
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# =============================================================================
# Email: resetare parolă — TREBUIE unul din două: (A) SMTP Zoho  SAU  (B) Resend
# =============================================================================

# Expeditor (obligatoriu pentru ambele). Ex: "VEX <noreply@domeniul-tău.md>"
EMAIL_FROM=

# --- (A) SMTP Zoho (recomandat) ---
# Host: verifică în Zoho Mail → SMTP (adesea smtppro.zoho.eu sau smtp.zoho.eu)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# --- (B) Resend (dacă NU folosești SMTP) ---
# RESEND_API_KEY=

# =============================================================================
# Producție (Render etc.) — vezi comentarii în README / documentație deploy
# =============================================================================
# DATABASE_URL=file:./data/prod.db
# NEXT_PUBLIC_APP_URL=https://vex.md
# NEXT_PUBLIC_SOCKET_URL=wss://...
